# ─── Azure OpenAI (LLM) ───────────────────────────────────────────────────────
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Azure OpenAI (Embeddings) ────────────────────────────────────────────────
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSION=1536

# ─── Azure AI Search (opcional, para escalar vectorstore) ────────────────────
AZURE_SEARCH_KEY=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_SECTOR=ficohsa-sector-index
AZURE_SEARCH_INDEX_FINANCIAL=ficohsa-financial-index

# ─── Configuración LLM ────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000
LLM_TOP_P=0.95

# ─── Configuración RAG ────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_SECTOR=8
TOP_K_FINANCIAL=6
RERANKER_TOP_N=5

# ─── Vectorstore ──────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vectorstore/faiss_index
SECTOR_INDEX_NAME=sector_index
FINANCIAL_INDEX_NAME=financial_index

# ─── Rutas de datos ───────────────────────────────────────────────────────────
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
INFORMES_GESTION_PATH=./data/raw/informes_gestion
ESTADOS_FINANCIEROS_PATH=./data/raw/estados_financieros

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ─── Evaluación (RAGAS) ───────────────────────────────────────────────────────
ENABLE_RAGAS=true
RAGAS_METRICS=faithfulness,answer_relevancy,context_precision,context_recall
EVALUATION_DATASET_PATH=./data/evaluation

# ─── Nombre del Asistente ─────────────────────────────────────────────────────
ASSISTANT_NAME=FicoCrédito AI
