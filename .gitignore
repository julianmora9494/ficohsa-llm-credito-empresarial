# ─── Datos y vectorstore ──────────────────────────────────────────────────────
# Estados financieros de empresas (documentos reales, no se versionan)
data/raw/estados_financieros/**
data/raw/informes_gestion/**/*.pdf
data/raw/informes_gestion/**/*.pptx

# Archivos de prueba (PDFs reales reservados para test manual en UI)
data/test/

# Chunks y evidencias procesadas
data/processed/chunks/
data/processed/evidences/

# Indices FAISS
# financial_index: stale, se regenera con: python scripts/ingest_documents.py --tipo financiero
data/vectorstore/faiss_index/financial_index/
# sector_index: incluido en el repo (21MB) — necesario para Streamlit Community Cloud

# Mantener estructura de carpetas vacías con .gitkeep
!data/raw/informes_gestion/honduras/.gitkeep
!data/raw/informes_gestion/guatemala/.gitkeep
!data/raw/informes_gestion/nicaragua/.gitkeep
!data/raw/estados_financieros/.gitkeep
!data/processed/chunks/.gitkeep
!data/processed/evidences/.gitkeep
!data/vectorstore/faiss_index/.gitkeep

